datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id        String   @id @default(cuid())
  name      String
  apiKey    String   @unique
  books     Book[]
  createdAt DateTime @default(now())
}

model Book {
  id          String     @id @default(cuid())
  userId      String
  user        User       @relation(fields: [userId], references: [id])
  title       String
  author      String
  isbn        String?
  status      String   @default("to_read")
  coverUrl    String?
  description String?
  createdAt   DateTime @default(now())
}
