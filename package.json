{
  "name": "cesi-library",
  "version": "1.0.0",
  "description": "REST API for managing personal book libraries",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsup src/server.ts --format cjs --dts",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "biome lint src",
    "format": "biome format src --write",
    "check": "biome check src",
    "migrate": "prisma migrate deploy",
    "migrate:create": "prisma migrate dev",
    "seed": "tsx prisma/seed.ts",
    "postinstall": "prisma generate",
    "prepare": "husky"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/adapter-better-sqlite3": "^7.7.0",
    "@prisma/client": "^7.7.0",
    "express": "^5.2.1"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.12",
    "@types/express": "^5.0.6",
    "@types/supertest": "^7.2.0",
    "husky": "^9.1.7",
    "prisma": "^7.7.0",
    "supertest": "^7.0.0",
    "tsup": "^8.3.5",
    "tsx": "^4.19.2",
    "typescript": "^6.0.3",
    "vitest": "^4.1.4"
  }
}
